# =============================================
# Scrollabus — Environment Variables
# Copy to .env.local and fill in values
# =============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# n8n Webhook URLs (required for AI pipelines)
# Set these after importing workflows into n8n and activating them
N8N_WEBHOOK_MATERIAL_TO_POST=http://localhost:5678/webhook/scrollabus-material-to-posts
N8N_WEBHOOK_COMMENT_REPLY=http://localhost:5678/webhook/scrollabus-comment-reply

# Gemini (required for PDF vision analysis, image generation, and TTS audio narrations)
# Used by: Next.js (PDF parse), n8n Nano Banana 2 image branch, n8n Gemini TTS audio branch
GEMINI_API_KEY=your-gemini-api-key

# Kling (required for AI video generation in n8n — set inside n8n as KLING_API_KEY)
# KLING_API_KEY=your-kling-key

# Featherless AI (set inside n8n, not in Next.js)
# Add FEATHERLESS_API_KEY as an env var in your n8n instance
# FEATHERLESS_API_KEY=your-featherless-key

# Google Sheet ID (for Creao bridge, Workflows 3 & 4)
# GOOGLE_SHEET_ID=your-google-sheet-id

# YouTube Data API v3
# Used by: n8n Workflow 5 (channel ingestion) AND Next.js /api/explore/search (live YouTube search)
# Get a key at: https://console.cloud.google.com/ → APIs & Services → YouTube Data API v3
# Set this in both your n8n instance AND here for live search to work
# No API key is needed for TikTok — Workflow 6 uses the public oEmbed endpoint
YOUTUBE_API_KEY=your-youtube-data-api-key

# ElevenLabs (TTS — https://elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# =============================================
# Memory-Native Agent Layer
# =============================================

# HydraDB — learner memory layer (https://hydradb.com)
# Stores long-term learner profiles, misconceptions, preferences, and study history
HYDRADB_API_KEY=your-hydradb-api-key
HYDRADB_TENANT_ID=scrollabus

# Dify — teaching agent workflow orchestration (https://dify.ai)
# Build the teaching workflow in the Dify UI, then grab the API key
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=your-dify-workflow-api-key

# GMI Cloud — OpenAI-compatible inference (https://gmicloud.ai)
# Used for DeepSeek and Llama model calls via Dify and direct Next.js routes
# API base: https://api.gmi-serving.com/v1
GMI_CLOUD_API_KEY=your-gmi-cloud-api-key

# Telegram Bot — ambient study companion
# Create a bot via @BotFather on Telegram, then paste the token here
# After deploying, call POST /api/telegram/setup-webhook to register the webhook
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
